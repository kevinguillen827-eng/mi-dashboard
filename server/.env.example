PORT=4000

# PostgreSQL (o adapta a MySQL cambiando el driver en config/db.js)
DATABASE_URL=postgres://usuario:password@localhost:5432/ledger_trading

# Firebase Admin SDK — descarga el JSON de credenciales de servicio desde
# Firebase Console > Configuración del proyecto > Cuentas de servicio,
# y referencia su ruta aquí (NO subir el archivo real al repositorio).
GOOGLE_APPLICATION_CREDENTIALS=./config/serviceAccountKey.json

CORS_ORIGIN=http://localhost:5173
